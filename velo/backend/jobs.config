/*
 * Wanderlust Booking Engine — Velo scheduled jobs config.
 * File location in Wix Editor: backend/jobs.config  (exact filename, no .js)
 *
 * Runs advanceStatuses() once a day to flip bookings:
 *   Confirmed -> In-House (on check-in date)
 *   In-House  -> Checked-Out (on check-out date)
 * Cancelled rows are skipped. Times are UTC. 05:00 UTC ~ early morning in
 * Dominica (AST, UTC-4 = 01:00 local) — adjust to taste.
 *
 * NOTE: status is ALSO computed on-the-fly when viewing a booking
 * (computeStatus in reporting.web.js / effective_status in Python), so the
 * display is always correct even between job runs. This job keeps the STORED
 * value in sync so reports/queries are accurate.
 */
{
  "jobs": [
    {
      "functionLocation": "/reporting.web.js",
      "functionName": "advanceStatuses",
      "description": "Advance booking statuses (Confirmed/In-House/Checked-Out)",
      "executionConfig": {
        "cronExpression": "0 5 * * *"
      }
    }
  ]
}
